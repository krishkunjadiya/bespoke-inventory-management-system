# Operating system / editor
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/

# Env files (never commit real secrets)
**/.env
**/.env.*
!**/.env.example

# Dependencies and build outputs
**/node_modules/
**/dist/
**/dist-ssr/
**/.cache/
**/.turbo/

# Logs
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test and coverage artifacts
**/coverage/
**/.nyc_output/

# Local runtime data
.mongo-data/
.mongo-logs/
**/.mongo/
**/.mongodb/

# Misc
*.local
